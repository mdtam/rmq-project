{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Makefile Binary",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/rmq", // CHANGE THIS to your output filename
      "args": ["input"], // Add arguments here if your program needs them
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb", // Use "lldb" if you are on macOS
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "make_debug" // This tells VS Code to run 'make' before starting
    }
  ]
}
